# Runtime
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
PORT=3000
API_PORT=3000
BOT_PORT=8090

# Security
JWT_SECRET=change-this-with-strong-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
ENCRYPTION_KEY=32-byte-base64-or-hex-key
CORS_ORIGINS=https://najmitdinov.github.io,http://127.0.0.1:5177,http://localhost:5177,http://127.0.0.1:8080,http://localhost:8080

# PostgreSQL
DATABASE_URL=postgres://ijro:ijro@localhost:5432/ijro_ai
DATABASE_SSL=false

# Firebase realtime/admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_SECRET=
TELEGRAM_TEST_CHAT_ID=1165868975
TELEGRAM_WEBHOOK_URL=https://your-api.example.com/api/telegram/webhook/update
PUBLIC_BACKEND_URL=https://your-railway-domain.up.railway.app

# AI provider keys: backend-only, never expose in frontend
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional notification providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
