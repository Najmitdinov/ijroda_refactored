rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function role() {
      return hasUserDoc() ? userData().role : 'user';
    }

    function isSuperadmin() {
      return role() == 'superadmin';
    }

    function isAdmin() {
      return role() in ['superadmin', 'admin'];
    }

    function isOrgAdmin() {
      return role() in ['superadmin', 'admin', 'org_admin'];
    }

    function isController() {
      return role() in ['superadmin', 'admin', 'org_admin', 'controller'];
    }

    function isAuditor() {
      return role() in ['superadmin', 'admin', 'auditor', 'controller'];
    }

    function sameOrg(org) {
      return signedIn() && org != null && hasUserDoc() && userData().org == org;
    }

    function owner(uid) {
      return signedIn() && uid != null && request.auth.uid == uid;
    }

    function canReadOrgDoc(data) {
      return signedIn() && (
        isAdmin() ||
        owner(data.userId) ||
        owner(data.uid) ||
        sameOrg(data.org) ||
        sameOrg(data.userOrg) ||
        sameOrg(data.organization_id)
      );
    }

    function canWriteOrgDoc(data) {
      return signedIn() && (
        isAdmin() ||
        owner(data.userId) ||
        owner(data.uid) ||
        (role() == 'org_admin' && (sameOrg(data.org) || sameOrg(data.userOrg) || sameOrg(data.organization_id)))
      );
    }

    match /users/{uid} {
      allow read: if signedIn() && (owner(uid) || isAdmin() || sameOrg(resource.data.org));
      allow create: if signedIn() && (owner(uid) || isAdmin());
      allow update: if signedIn() && (
        owner(uid) ||
        isAdmin() ||
        (role() == 'org_admin' && sameOrg(resource.data.org))
      );
      allow delete: if isSuperadmin();

      match /chats/{chatId} {
        allow read, write: if owner(uid);
        match /messages/{msgId} {
          allow read, write: if owner(uid);
        }
      }
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if isSuperadmin();
    }

    match /documents/{docId} {
      allow read: if canReadOrgDoc(resource.data);
      allow create: if signedIn();
      allow update: if canWriteOrgDoc(resource.data) || canWriteOrgDoc(request.resource.data);
      allow delete: if isAdmin() || owner(resource.data.userId);
    }

    match /logs/{logId} {
      allow create: if signedIn();
      allow read: if isAuditor();
      allow update, delete: if false;
    }

    match /aiLogs/{logId} {
      allow create: if signedIn();
      allow read: if isAuditor();
      allow update, delete: if false;
    }

    match /aiUsage/{usageId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if isSuperadmin();
    }

    match /security/{uid}/{document=**} {
      allow read, write: if signedIn() && (owner(uid) || isAdmin());
    }

    match /security_log/{logId} {
      allow create: if signedIn();
      allow read: if isAuditor();
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if canReadOrgDoc(resource.data);
      allow create: if signedIn();
      allow update: if signedIn() && role() in ['superadmin', 'admin', 'org_admin', 'department_head', 'controller'];
      allow delete: if isAdmin();
    }

    match /analytics/{id} {
      allow read: if isAdmin();
      allow create, update: if signedIn();
      allow delete: if isSuperadmin();
    }

    match /subscriptions/{id} {
      allow read: if isAdmin() || owner(resource.data.uid);
      allow write: if isSuperadmin();
    }

    match /fishkalar/{id} {
      allow read, write: if signedIn();
    }

    match /xodimlar/{id} {
      allow read, write: if signedIn();
    }

    match /sektorlar/{id} {
      allow read, write: if signedIn();
    }

    match /tashkilotlar/{id} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /muhim_topshiriqlar/{id} {
      allow read, write: if signedIn();
    }

    match /ai_hisobot_buyruqlar/{id} {
      allow read: if signedIn();
      allow write: if isOrgAdmin();
    }

    match /ai_document_templates/{id} {
      allow read: if signedIn();
      allow create, update: if isOrgAdmin();
      allow delete: if isAdmin();
    }

    match /ai_knowledge_documents/{id} {
      allow read: if signedIn();
      allow create, update: if isOrgAdmin();
      allow delete: if isAdmin();
    }

    match /ai_learning_blankas/{id} {
      allow read: if signedIn();
      allow create, update: if isOrgAdmin();
      allow delete: if isAdmin();
    }

    match /ai_learning_memory/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrgAdmin();
      allow delete: if isAdmin();
    }

    match /ai_generated_documents/{id} {
      allow read, write: if signedIn();
    }

    match /legal_documents/{id} {
      allow read: if signedIn();
      allow create, update: if isController();
      allow delete: if isSuperadmin();
    }

    match /legal_knowledge_base/{id} {
      allow read: if signedIn();
      allow create, update: if isOrgAdmin();
      allow delete: if isAdmin();
    }

    match /legal_document_chunks/{id} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if isSuperadmin();
    }

    match /document_analysis/{id} {
      allow read: if canReadOrgDoc(resource.data);
      allow create: if signedIn();
      allow update: if isController();
      allow delete: if isSuperadmin();
    }

    match /extracted_tasks/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isController();
      allow delete: if isSuperadmin();
    }

    match /ai_answers/{id} {
      allow read: if canReadOrgDoc(resource.data);
      allow create: if signedIn();
      allow update, delete: if false;
    }

    match /ai_audit_logs/{id} {
      allow create: if signedIn();
      allow read: if isAuditor();
      allow update, delete: if false;
    }

    match /construction_checklists/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isController();
      allow delete: if isSuperadmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
